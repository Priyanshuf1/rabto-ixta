{
  "name": "rabto-ixta",
  "version": "1.0.0",
  "description": "Instagram data extraction tool — lookup user IDs and explore similar accounts. Run locally in one command.",
  "type": "module",
  "bin": {
    "rabto-ixta": "./cli.js"
  },
  "scripts": {
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "install-all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "keywords": [
    "instagram",
    "instagram-id",
    "instagram-lookup",
    "rabto-ixta",
    "social-media-tools",
    "rapidapi"
  ],
  "author": "Priyanshu Awasthi",
  "license": "MIT",
  "homepage": "https://github.com/Priyanshuf1/rabto-ixta#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Priyanshuf1/rabto-ixta.git"
  },
  "bugs": {
    "url": "https://github.com/Priyanshuf1/rabto-ixta/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@vercel/kv": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  }
}
